
SQL_SERVER=sqlserver
SQL_PORT=1433
SQL_USER=sa
SQL_PASSWORD=

VITE_API_BASE_URL=/api

AUTH_DB=AuthDb
PROFILE_DB=ProfileDb
BOOKING_DB=BookingDb
WORKSHIFT_DB=WorkShiftDb

AUTH_CONNECTION_STRING=Server=${SQL_SERVER},${SQL_PORT};Database=${AUTH_DB};User Id=${SQL_USER};Password=${SQL_PASSWORD};TrustServerCertificate=True;
PROFILE_CONNECTION_STRING=Server=${SQL_SERVER},${SQL_PORT};Database=${PROFILE_DB};User Id=${SQL_USER};Password=${SQL_PASSWORD};TrustServerCertificate=True;
BOOKING_CONNECTION_STRING=Server=${SQL_SERVER},${SQL_PORT};Database=${BOOKING_DB};User Id=${SQL_USER};Password=${SQL_PASSWORD};TrustServerCertificate=True;
WORKSHIFT_CONNECTION_STRING=Server=${SQL_SERVER},${SQL_PORT};Database=${WORKSHIFT_DB};User Id=${SQL_USER};Password=${SQL_PASSWORD};TrustServerCertificate=True;