{
  "ServiceHealthUrls": {
    "Auth": "http://auth-api:8080/health",
    "Profile": "http://profile-api:8080/health",
    "Booking": "http://booking-api:8080/health",
    "Workshift": "http://workshift-api:8080/health"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "auth-api-route": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "profile-route": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        }
      },
      "profile-api-route": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "booking-route": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        }
      },
      "booking-api-route": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "workshift-route": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/workshift/{**catch-all}"
        }
      },
      "workshift-api-route": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/api/workshift/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      }
    },

    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authService": {
            "Address": "http://auth-api:8080/"
          }
        }
      },
      "profileCluster": {
        "Destinations": {
          "profileService": {
            "Address": "http://profile-api:8080/"
          }
        }
      },
      "workshiftCluster": {
        "Destinations": {
          "workshiftService": {
            "Address": "http://workshift-api:8080/"
          }
        }
      },
      "bookingCluster": {
        "Destinations": {
          "bookingService": {
            "Address": "http://booking-api:8080/"
          }
        }
      }
    }
  }
}