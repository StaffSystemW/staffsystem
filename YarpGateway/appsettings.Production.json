{
  "ReverseProxy": {
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authService": {
            "Address": "http://auth:8080/"
          }
        }
      },
      "profileCluster": {
        "Destinations": {
          "profileService": {
            "Address": "http://profile:8080/"
          }
        }
      },
      "workshiftCluster": {
        "Destinations": {
          "workshiftService": {
            "Address": "http://workshift:8080/"
          }
        }
      },
      "bookingCluster": {
        "Destinations": {
          "bookingService": {
            "Address": "http://booking:8080/"
          }
        }
      }
    },
    "Routes": {
      "auth-api": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },
      "profile-api": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "booking-api": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      },
      "workshift-api": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/api/workshift/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      }
    }
  }
}




